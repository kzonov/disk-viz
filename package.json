{
  "name": "disk-viz",
  "version": "1.0.0",
  "description": "macOS Disk Usage Visualizer",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.kzonov.disk-viz",
    "productName": "Disk Viz",
    "afterSign": "scripts/after-sign.js",
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg",
      "identity": null,
      "icon": "docs/icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "scanner-worker.js",
      "index.html",
      "about.html",
      "lib/**",
      "styles/**",
      "renderer/**",
      "docs/icon.png",
      "node_modules/d3/**"
    ]
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "d3": "^7.9.0"
  }
}
